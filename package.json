{
  "name": "video-voice-app-v2",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "fmt:sv": "prettier --write '**/*.svelte'"
  },
  "dependencies": {
    "@jtclarkjr/supabase-ts-rest": "github:jtclarkjr/supabase-ts-rest#v0.2.5",
    "clsx": "^2.1.1",
    "lucide-svelte": "^1.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.18",
    "vite-plus": "^0.1.18"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "cookie": ">=0.7.0"
  },
  "packageManager": "bun@1.3.12",
  "patchedDependencies": {
    "@sveltejs/kit@2.57.1": "patches/@sveltejs%2Fkit@2.57.1.patch"
  }
